---
layout: false

import SectionReveal from '../components/SectionReveal.astro';
import SectionHeading from '../components/SectionHeading.astro';

const projects = [
  {
    id: 1,
    url: "furryfriends.codexmill.com",
    image: "/1ff.png",
  },
  {
    id: 2,
    url: "greenyards.codexmill.com",
    image: "/2gy.png",
  },
  {
    id: 3,
    url: "mareeaesthetics.codexmill.com",
    image: "/3ms.png",
  },
    {
    id: 4,
    url: "thepoolcleaners.codexmill.com",
    image: "/4tpc.png",
  },
    {
    id: 3,
    url: "dezignexperts.codexmill.com",
    image: "/5de.png",
  },
    {
    id: 3,
    url: "orbis783.codexmill.com",
    image: "/6o7.png",
  }
];
---

<section id="portfolio-section" class="relative w-full bg-white text-gray-900">
  
  <!-- ========================================== -->
  <!-- HEADING - NORMAL SCROLL                    -->
  <!-- ========================================== -->
  <div class="container-page pt-16 pb-8 md:pt-24 md:pb-12">
    <SectionReveal>
      <SectionHeading
        eyebrow="The brochure trap"
        heading="Most Small-Business Sites"
        highlight="Just Sit There."
        subhead="Good design isn't enough if your site doesn't convert. Without automated follow-ups or clear booking paths, you're losing leads every day. We've designed a better way to capture and convert your traffic. Take a look:"
      />
    </SectionReveal>
  </div>

  <!-- ========================================== -->
  <!-- CARDS AREA - STICKY SCROLL ANIMATION       -->
  <!-- ========================================== -->
  <div id="portfolio-cards-area" class="relative w-full">
    
    <!-- Scroll track - tall enough for all card transitions -->
    <div class="portfolio-scroll-track relative w-full" style="height: 350vh;">
      
      <!-- Sticky viewport -->
      <div class="sticky top-0 h-screen w-full flex items-center justify-center overflow-hidden px-4 py-8 md:py-12">
        
        <!-- Card container - FULL WIDTH like header/footer -->
        <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-center justify-center">
          
          {projects.map((project, index) => (
            <div 
              class="portfolio-card absolute w-full will-change-transform"
              data-index={index}
              style={`z-index: ${projects.length - index};`}
            >
              <!-- Card - wide, proper height -->
              <div class="absolute w-full flex justify-center top-[17%] overflow-hidden">
                
                <!-- Card Inner with proper padding -->
                    <a 
                      href={`https://${project.url}/`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-sky-500 hover:text-sky-600 font-medium text-xs md:text-base transition-colors"
                      
                    >
                      <span class="underline underline-offset-4">{project.url}</span>
                      <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </a>
                  </div>
                      <a href={`https://${project.url}/`} target="_blank" rel="noopener noreferrer" >
                      <img 
                        src={project.image} 
                        alt={`${project.name} Portfolio`}
                        class="w-full h-full rounded-xl"
                        loading={index === 0 ? "eager" : "lazy"}
                        decoding="async"
                      />
                      </a>
                    </div>
                  </a>
                </div>
              </div>

              <!-- Overlay for previous cards -->
              <div class="card-overlay absolute inset-0 bg-black/0 rounded-2xl md:rounded-3xl pointer-events-none transition-colors duration-500" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ========================================== */
  /* MOBILE RESPONSIVE - BELOW 768px            */
  /* ========================================== */
  @media (max-width: 167px) {
    /* Scroll track becomes auto height */
    .portfolio-scroll-track {
      height: auto !important;
    }
    
    /* Sticky becomes relative (normal flow) */
    .sticky {
      position: relative !important;
      height: auto !important;
      min-height: auto !important;
      padding-top: 2rem !important;
      padding-bottom: 2rem !important;
    }
    
    /* Cards stack normally */
    .portfolio-card {
      position: relative !important;
      width: 100% !important;
      margin-bottom: 1.5rem;
      transform: none !important;
      opacity: 1 !important;
      z-index: auto !important;
    }
    
    .portfolio-card:last-child {
      margin-bottom: 0;
    }
    
    /* Hide dots and overlays on mobile */
    .portfolio-dot,
    .card-overlay {
      display: none !important;
    }
  }

  /* ========================================== */
  /* TABLET - 768px to 1023px                   */
  /* ========================================== */
  @media (min-width: 168px) and (max-width: 1023px) {
    .portfolio-scroll-track {
      height: 300vh;
    }
  }

  /* ========================================== */
  /* DOT ACTIVE STATE                           */
  /* ========================================== */
  .portfolio-dot.active {
    background-color: #0ea5e9;
    transform: scale(1.5);
    box-shadow: 0 0 16px rgba(14, 165, 233, 0.5);
  }
  
  .portfolio-dot:not(.active) {
    opacity: 0.5;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  let initialized = false;

  function initPortfolioAnimation() {
    if (initialized) return;
    initialized = true;

    const scrollTrack = document.querySelector('.portfolio-scroll-track');
    const cards = document.querySelectorAll('.portfolio-card');
    const dots = document.querySelectorAll('.portfolio-dot');

    if (!scrollTrack || cards.length < 2) return;

    const mm = gsap.matchMedia();

    // ==========================================
    // DESKTOP + TABLET (768px and up)
    // ==========================================
    mm.add("(min-width: 168px)", () => {
      
      // Initial states
      gsap.set(cards[0], { 
        yPercent: 0, 
        scale: 1, 
        opacity: 1,
        rotateX: 0 
      });
      gsap.set(cards[0].querySelector('.card-overlay'), { backgroundColor: 'rgba(0,0,0,0)' });

      for (let i = 1; i < cards.length; i++) {
        gsap.set(cards[i], { 
          yPercent: 100, 
          scale: 0.85, 
          opacity: 0,
          rotateX: 8 
        });
      }

      // Update dots based on progress
      const updateDots = (progress) => {
        const segmentSize = 1 / cards.length;
        const activeIndex = Math.min(Math.floor(progress / segmentSize), cards.length - 1);
        
        dots.forEach((dot, i) => {
          if (i === activeIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      };

      // Master timeline
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: scrollTrack,
          start: "top top",
          end: "bottom bottom",
          scrub: 0.8,
          invalidateOnRefresh: true,
          fastScrollEnd: true,
          onUpdate: (self) => updateDots(self.progress)
        }
      });

      const segmentDuration = 1;

      for (let i = 0; i < cards.length - 1; i++) {
        const t = i * segmentDuration;
        
        // Next card slides UP from bottom
        tl.to(cards[i + 1], { 
          yPercent: 0, 
          scale: 1, 
          opacity: 1,
          rotateX: 0,
          duration: segmentDuration, 
          ease: "power2.inOut" 
        }, t);
        
        // Current card exits UP + scales down + fades
        tl.to(cards[i], { 
          yPercent: -60, 
          scale: 0.8, 
          opacity: 0,
          rotateX: -5,
          duration: segmentDuration, 
          ease: "power2.inOut" 
        }, t);
        
        // Current card darkens slightly
        tl.to(cards[i].querySelector('.card-overlay'), { 
          backgroundColor: "rgba(0,0,0,0.15)", 
          duration: segmentDuration 
        }, t);
      }

      // Click dots to navigate
      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          const targetY = scrollTrack.offsetTop + (scrollTrack.offsetHeight * (index / cards.length));
          window.scrollTo({ top: targetY, behavior: 'smooth' });
        });
      });

      return () => {
        gsap.set(cards, { clearProps: "all" });
        cards.forEach(c => {
          const o = c.querySelector('.card-overlay');
          if (o) gsap.set(o, { clearProps: "all" });
        });
      };
    });

    // ==========================================
    // MOBILE (below 768px) - Fade up on scroll
    // ==========================================
    mm.add("(max-width: 767px)", () => {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            gsap.fromTo(entry.target, 
              { opacity: 0, y: 50, scale: 0.95 },
              { opacity: 1, y: 0, scale: 1, duration: 0.7, ease: "power2.out" }
            );
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });

      cards.forEach(card => {
        gsap.set(card, { opacity: 0, y: 50, scale: 0.95 });
        observer.observe(card);
      });

      return () => observer.disconnect();
    });
  }

  document.addEventListener('astro:page-load', initPortfolioAnimation);
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initPortfolioAnimation();
  } else {
    document.addEventListener('DOMContentLoaded', initPortfolioAnimation);
  }
</script>