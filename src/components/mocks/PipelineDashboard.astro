---
/**
 * PipelineDashboard — stylised (NOT real-product) CRM dashboard for laptop/browser
 * mocks: metric tiles, a lead/job pipeline, and a grow-on-scroll bar chart.
 * Labels are configurable so industry pages can theme it.
 */
interface Props {
  title?: string;
  metrics?: { label: string; value: string; accent?: 'forge' | 'circuit' | 'green' }[];
  columns?: { name: string; count: number }[];
}
const {
  title = 'Pipeline',
  metrics = [
    { label: 'New leads', value: '24', accent: 'circuit' },
    { label: 'Booked', value: '38', accent: 'green' },
    { label: 'Revenue', value: '$42k', accent: 'forge' },
  ],
  columns = [
    { name: 'New', count: 5 },
    { name: 'Quoted', count: 3 },
    { name: 'Booked', count: 4 },
  ],
} = Astro.props;

const accent: Record<string, string> = {
  forge: 'text-forge',
  circuit: 'text-circuit',
  green: 'text-[#1FA34A]',
};
const bars = [42, 58, 71, 64, 88, 76, 95];
---

<div class="space-y-4 p-5">
  <div class="flex items-center justify-between">
    <div>
      <p class="text-[0.7rem] font-medium uppercase tracking-wider text-cool">CodexMill</p>
      <p class="font-display text-base font-bold text-navy">{title}</p>
    </div>
    <div class="flex gap-1.5">
      <span class="h-6 w-6 rounded-md bg-mist"></span>
      <span class="h-6 w-6 rounded-md bg-mist"></span>
      <span class="h-6 w-6 rounded-md bg-forge/15"></span>
    </div>
  </div>

  <!-- metrics -->
  <div class="grid grid-cols-3 gap-2.5">
    {
      metrics.map((m) => (
        <div class="rounded-xl bg-mist p-3">
          <p class="text-[0.62rem] font-medium uppercase tracking-wide text-cool">{m.label}</p>
          <p class={`mt-0.5 font-display text-xl font-extrabold ${accent[m.accent ?? 'forge']}`}>{m.value}</p>
        </div>
      ))
    }
  </div>

  <!-- pipeline + chart -->
  <div class="grid grid-cols-[1.3fr_1fr] gap-2.5">
    <div class="grid grid-cols-3 gap-2 rounded-xl border border-hairline p-2.5">
      {
        columns.map((c) => (
          <div class="space-y-1.5">
            <p class="text-[0.6rem] font-semibold text-cool">{c.name}</p>
            {Array.from({ length: Math.min(c.count, 3) }).map(() => (
              <div class="rounded-md bg-mist p-1.5">
                <div class="h-1 w-8 rounded bg-navy/15" />
                <div class="mt-1 h-1 w-5 rounded bg-navy/10" />
              </div>
            ))}
          </div>
        ))
      }
    </div>
    <div class="flex items-end justify-between gap-1 rounded-xl border border-hairline p-2.5">
      {
        bars.map((h) => (
          <div class="flex h-full flex-1 items-end">
            <div class="cm-bar w-full rounded-t bg-gradient-to-t from-forge/30 to-forge/70" style={`--h:${h}%`} />
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .cm-bar { height: var(--h); }
  @media (prefers-reduced-motion: no-preference) {
    .cm-bar {
      height: 0;
      animation: bar-grow 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes bar-grow { to { height: var(--h); } }
  }
</style>
