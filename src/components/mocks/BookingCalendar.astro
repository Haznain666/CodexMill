---
/**
 * BookingCalendar — stylised (NOT real-product) booking calendar for laptop/browser
 * mocks. Themeable accent + appointment labels so med spa / pet / home-services
 * pages can reuse it.
 */
interface Appt {
  time: string;
  label: string;
  accent?: 'forge' | 'circuit' | 'green';
}
interface Props {
  title?: string;
  appts?: Appt[];
}
const {
  title = 'Bookings',
  appts = [
    { time: '9:00', label: 'New consult', accent: 'circuit' },
    { time: '10:30', label: 'Follow-up', accent: 'forge' },
    { time: '1:00', label: 'Rebooking', accent: 'green' },
    { time: '3:30', label: 'New booking', accent: 'circuit' },
  ],
} = Astro.props;

const days = ['M', 'T', 'W', 'T', 'F', 'S'];
const bg: Record<string, string> = {
  forge: 'bg-forge/12 text-forge ring-forge/20',
  circuit: 'bg-circuit/12 text-circuit ring-circuit/20',
  green: 'bg-[#28C840]/12 text-[#1FA34A] ring-[#28C840]/20',
};
// which day cells show a "filled" dot (stylised availability)
const filled = [1, 2, 4, 5, 8, 9, 10, 13, 15, 16];
---

<div class="space-y-4 p-5">
  <div class="flex items-center justify-between">
    <div>
      <p class="text-[0.7rem] font-medium uppercase tracking-wider text-cool">CodexMill</p>
      <p class="font-display text-base font-bold text-navy">{title}</p>
    </div>
    <span class="rounded-full bg-[#28C840]/10 px-2.5 py-1 text-[0.65rem] font-bold text-[#1FA34A]">Calendar full</span>
  </div>

  <!-- mini month grid -->
  <div class="rounded-xl border border-hairline p-3">
    <div class="grid grid-cols-6 gap-1.5">
      {days.map((d) => <span class="text-center text-[0.6rem] font-semibold text-cool">{d}</span>)}
      {
        Array.from({ length: 18 }).map((_, i) => (
          <span class:list={['grid h-6 place-items-center rounded-md text-[0.6rem] font-medium', filled.includes(i) ? 'bg-forge/10 text-forge' : 'bg-mist text-cool']}>
            {i + 6}
          </span>
        ))
      }
    </div>
  </div>

  <!-- today's appts -->
  <div class="space-y-2">
    {
      appts.map((a) => (
        <div class="flex items-center gap-3 rounded-xl border border-hairline bg-white p-2.5">
          <span class={`grid h-9 w-12 shrink-0 place-items-center rounded-lg text-xs font-bold ring-1 ${bg[a.accent ?? 'forge']}`}>{a.time}</span>
          <div class="flex-1">
            <div class="h-1.5 w-20 rounded bg-navy/15"></div>
            <p class="mt-1 text-[0.7rem] font-medium text-slate">{a.label}</p>
          </div>
          <span class="text-[#1FA34A]">✓</span>
        </div>
      ))
    }
  </div>
</div>
