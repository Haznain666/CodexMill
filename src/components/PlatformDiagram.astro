---
/**
 * PlatformDiagram — all-in-one platform hub: a central GoHighLevel hub with
 * Capture → Nurture → Convert → Retain nodes orbiting it, connected by lines
 * with pulses traveling outward. `light` for the navy GHL hero.
 * Decorative; labelled via role/aria.
 */
import Icon from './Icon.astro';

interface Props {
  light?: boolean;
  class?: string;
}
const { light = false, class: className = '' } = Astro.props;

// positions around the hub (top, right, bottom, left)
const nodes = [
  { icon: 'bolt', label: 'Capture', sub: 'Funnels & forms', pos: 'top' },
  { icon: 'refresh', label: 'Nurture', sub: 'Automated follow-up', pos: 'right' },
  { icon: 'pipeline', label: 'Convert', sub: 'Sales pipelines', pos: 'bottom' },
  { icon: 'star', label: 'Retain', sub: 'Reviews & reactivation', pos: 'left' },
];

const place: Record<string, string> = {
  top: 'left-1/2 top-0 -translate-x-1/2 -translate-y-1/2',
  right: 'right-0 top-1/2 translate-x-1/2 -translate-y-1/2',
  bottom: 'left-1/2 bottom-0 -translate-x-1/2 translate-y-1/2',
  left: 'left-0 top-1/2 -translate-x-1/2 -translate-y-1/2',
};

const card = light
  ? 'border-white/15 bg-white/[0.08] text-white'
  : 'border-hairline bg-white text-navy shadow-card';
const sub = light ? 'text-white/55' : 'text-cool';
const chip = light ? 'bg-white/10 text-forge-500' : 'bg-forge-blue-soft text-navy ring-1 ring-hairline';
const lineColor = light ? 'rgba(255,255,255,0.18)' : 'rgba(11,26,48,0.10)';
---

<div class={`relative mx-auto aspect-square w-full max-w-[30rem] ${className}`} role="img" aria-label="GoHighLevel as one platform: Capture, Nurture, Convert, and Retain connect to a single hub.">
  <!-- connector lines + pulses -->
  <svg viewBox="0 0 100 100" class="absolute inset-0 h-full w-full" aria-hidden="true">
    <g stroke={lineColor} stroke-width="0.6">
      <line x1="50" y1="50" x2="50" y2="12" />
      <line x1="50" y1="50" x2="88" y2="50" />
      <line x1="50" y1="50" x2="50" y2="88" />
      <line x1="50" y1="50" x2="12" y2="50" />
    </g>
    <g fill="#F26419">
      <circle r="1.3" class="cm-pulse"><animateMotion dur="2.6s" repeatCount="indefinite" path="M50,50 L50,12" /></circle>
      <circle r="1.3" class="cm-pulse"><animateMotion dur="2.6s" begin="0.6s" repeatCount="indefinite" path="M50,50 L88,50" /></circle>
      <circle r="1.3" class="cm-pulse"><animateMotion dur="2.6s" begin="1.2s" repeatCount="indefinite" path="M50,50 L50,88" /></circle>
      <circle r="1.3" class="cm-pulse"><animateMotion dur="2.6s" begin="1.8s" repeatCount="indefinite" path="M50,50 L12,50" /></circle>
    </g>
  </svg>

  <!-- center hub -->
  <div class="absolute left-1/2 top-1/2 z-10 -translate-x-1/2 -translate-y-1/2">
    <div class="grid h-28 w-28 place-items-center rounded-full bg-forge-blue text-center shadow-glow">
      <div>
        <p class="font-display text-sm font-extrabold leading-none text-white">GoHigh<br />Level</p>
        <p class="mt-1 text-[0.55rem] font-semibold uppercase tracking-widest text-white/80">One platform</p>
      </div>
    </div>
  </div>

  <!-- orbiting nodes -->
  {
    nodes.map((n, i) => (
      <div class={`absolute z-10 w-32 ${place[n.pos]}`}>
        <div class={`cm-orbit flex items-center gap-2.5 rounded-xl border p-2.5 ${card}`} style={`--i:${i}`}>
          <span class={`grid h-9 w-9 shrink-0 place-items-center rounded-lg ${chip}`}>
            <Icon name={n.icon as any} size={18} />
          </span>
          <div class="leading-tight">
            <p class="text-xs font-bold">{n.label}</p>
            <p class={`text-[0.6rem] ${sub}`}>{n.sub}</p>
          </div>
        </div>
      </div>
    ))
  }
</div>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .cm-orbit {
      animation: orbit-in 0.55s cubic-bezier(0.16, 1, 0.3, 1) backwards;
      animation-delay: calc(var(--i) * 140ms + 200ms);
    }
    @keyframes orbit-in {
      from { opacity: 0; transform: scale(0.92); }
      to { opacity: 1; transform: none; }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cm-pulse { display: none; }
  }
</style>
