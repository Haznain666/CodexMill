---
/**
 * SelectField — FormField + styled native <select> with a chevron.
 * Native select keeps it accessible + keyboard-friendly with zero JS.
 */
import FormField from './FormField.astro';
import Icon from '../Icon.astro';

interface Props {
  label: string;
  name: string;
  options: string[];
  placeholder?: string;
  required?: boolean;
  help?: string;
  class?: string;
}
const { label, name, options, placeholder = 'Select an option', required = false, help, class: className = '' } =
  Astro.props;

const selectBase =
  'w-full cursor-pointer appearance-none rounded-xl border border-hairline bg-white px-4 py-3 pr-11 text-[0.95rem] text-navy transition focus:border-forge focus:outline-none focus:ring-2 focus:ring-forge/20';
---

<FormField label={label} name={name} required={required} help={help} class={className}>
  <div class="relative">
    <select id={name} name={name} class={selectBase}>
      <option value="" disabled selected>{placeholder}</option>
      {options.map((o) => <option value={o}>{o}</option>)}
    </select>
    <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-cool">
      <Icon name="arrow-right" size={16} class="rotate-90" />
    </span>
  </div>
</FormField>
