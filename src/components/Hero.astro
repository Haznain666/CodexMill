---
/**
 * Hero — reusable page hero. Staggered entrance of eyebrow → headline →
 * subhead → CTAs → visual slot (CLAUDE.md §4A). The `visual` slot holds the
 * per-page signature graphic (device cluster, flow, diagram, etc.).
 * `light` renders on a navy band (used by the GHL page).
 */
import { GET_STARTED_URL, CTA_LABEL } from '../config/site';
import Button from './Button.astro';
import AmbientBackground from './AmbientBackground.astro';

interface Props {
  eyebrow?: string;
  headline: string;
  /** trailing phrase rendered with the gradient highlight */
  highlight?: string;
  subhead?: string;
  /** small line under the CTAs (e.g. "Done-for-you setup · Built on GoHighLevel") */
  trustLine?: string;
  subTagline?: string;
  /** primary CTA destination (defaults to the external booking calendar) */
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  light?: boolean;
  /** layout: split (text + visual) or centered (text only / visual below) */
  layout?: 'split' | 'centered';
  class?: string;
}
const {
  eyebrow,
  headline,
  highlight,
  subhead,
  trustLine,
  subTagline,
  ctaHref = GET_STARTED_URL,
  secondaryLabel,
  secondaryHref = '#how-it-works',
  light = false,
  layout = 'split',
  class: className = '',
} = Astro.props;

const hasVisual = Astro.slots.has('visual');
const split = layout === 'split' && hasVisual;

const headColor = light ? 'text-white' : 'text-navy';
const subColor = light ? 'text-white/75' : 'text-slate';
const bandCls = light ? 'bg-navy' : 'bg-white';
---

<section class={`relative overflow-hidden ${bandCls} ${className}`}>
  {!light && <AmbientBackground variant="hero" />}
  {
    light && (
      <div class="pointer-events-none absolute inset-0 -z-0 opacity-60" aria-hidden="true">
        <div class="absolute -left-20 top-0 h-96 w-96 rounded-full bg-forge/20 blur-3xl motion-safe:animate-drift" />
        <div class="absolute right-0 top-1/3 h-96 w-96 rounded-full bg-circuit/25 blur-3xl motion-safe:animate-drift" style="animation-delay:-7s" />
      </div>
    )
  }

  <div
    class:list={[
      'container-page relative grid items-center gap-12 py-16 sm:py-20 lg:py-24',
      split ? 'lg:grid-cols-[1.05fr_0.95fr]' : 'place-items-center text-center',
    ]}
  >
    <!-- Copy column -->
    <div class={split ? '' : 'max-w-3xl'}>
      {
        eyebrow && (
          <p
            class:list={['hero-stagger inline-flex items-center gap-2 rounded-full border border-hairline bg-white/70 px-3.5 py-1.5 text-xs font-semibold uppercase tracking-[0.14em]', light ? 'text-forge-500' : 'text-ember']}
            style={light ? 'background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.15)' : undefined}
          >
            {eyebrow}
          </p>
        )
      }
      <h1
        class={`hero-stagger mt-5 text-display-sm sm:text-display lg:text-display-lg ${headColor}`}
        style="animation-delay:80ms"
      >
        {headline}
        {highlight && <> <span class="text-gradient">{highlight}</span></>}
      </h1>
      {
        subTagline && (
          <p class:list={['hero-stagger mt-4 font-display text-lg font-bold', light ? 'text-forge-500' : 'text-ember']} style="animation-delay:140ms">
            {subTagline}
          </p>
        )
      }
      {
        subhead && (
          <p class={`hero-stagger mt-5 max-w-xl text-lg leading-relaxed ${subColor} ${split ? '' : 'mx-auto'}`} style="animation-delay:200ms">
            {subhead}
          </p>
        )
      }
      <div
        class:list={['hero-stagger mt-8 flex flex-wrap gap-3', split ? '' : 'justify-center']}
        style="animation-delay:280ms"
      >
        <Button href={ctaHref} size="lg">{CTA_LABEL}</Button>
        {
          secondaryLabel && (
            <Button href={secondaryHref} variant={light ? 'white' : 'secondary'} size="lg">
              {secondaryLabel}
            </Button>
          )
        }
      </div>
      {
        trustLine && (
          <p class={`hero-stagger mt-5 text-sm ${light ? 'text-white/55' : 'text-cool'}`} style="animation-delay:340ms">
            {trustLine}
          </p>
        )
      }
    </div>

    <!-- Visual column -->
    {
      hasVisual && (
        <div class="hero-stagger relative" style="animation-delay:380ms">
          <slot name="visual" />
        </div>
      )
    }
  </div>
</section>

<style>
  .hero-stagger {
    opacity: 0;
    transform: translateY(18px);
    animation: hero-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes hero-in {
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-stagger {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
