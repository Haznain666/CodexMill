---

/**

* TERMS OF SERVICE
  */
  import BaseLayout from '../layouts/BaseLayout.astro';
  import { SITE } from '../config/site';

const sections = [
{
h: 'SERVICES',
p: 'Codex Mill, a DBA of Dispatch Globally LLC provides GoHighLevel (GHL) automation consulting and implementation services for home service businesses, including but not limited to:',
ul: [
'CRM setup and workflow automation',
'Lead recovery and follow-up systems',
'SMS, email, and pipeline automation',
'Ongoing automation management and optimization (retainer services)',
'All other services that can be provided using GHL or other software.',
],
p2: 'Specific deliverables, timelines, and pricing are outlined in individual project proposals or service agreements provided to each client.',
},

{
h: 'CLIENT RESPONSIBILITIES',
p: 'By engaging our services, you agree to:',
ul: [
'Provide accurate business information required to complete the project',
'Grant necessary access to your GHL account, CRM, or other platforms as required',
'Review and approve deliverables within agreed timelines',
'Make timely payments as outlined in your service agreement',
],
p2: 'Delays caused by the client’s failure to provide required information or access may result in project timeline extensions without additional cost to Codex Mill.',
},

{
h: 'FEES AND PAYMENT',
p: 'Our service fees are outlined in your individual project proposal. General terms:',
ul: [
'Setup fees are due upon project commencement or as agreed in writing',
'Monthly retainer fees are billed at the start of each month',
'Payments are processed via Payoneer to Dispatch Globally LLC',
'All fees are quoted and invoiced in USD',
],
p2: 'We reserve the right to suspend services for accounts with outstanding balances beyond 14 days past the due date.',
},

{
h: 'REFUND POLICY',
p: 'Due to the custom nature of our services:',
ul: [
'Setup fees are non-refundable once work has commenced',
'Monthly retainer fees are non-refundable for the current billing period',
'If a project is cancelled before work begins, a full refund of setup fees will be issued',
'Disputes regarding deliverable quality will be resolved through a revision process outlined in your service agreement.',
],
},

{
h: 'INTELLECTUAL PROPERTY',
p: 'All custom automation workflows, funnel templates, and other deliverables created by Codex Mill, a DBA of Dispatch Globally LLC for a client become the property of that client upon full payment.',
p2: 'Codex Mill, a DBA of Dispatch Globally LLC retains the right to use anonymized, non-identifiable project examples in our portfolio and marketing materials unless otherwise agreed in writing. Codex Mill, a DBA of Dispatch Globally LLC brand, website content, and proprietary methodologies remain the exclusive property of Dispatch Globally LLC.',
},

{
h: 'CONFIDENTIALITY',
p: 'We treat all client business information as confidential. We will not disclose your business data, automation workflows, or client lists to third parties without your consent, except as required by law or as necessary to deliver the services (e.g., platform providers).',
},

{
h: 'THIRD-PARTY PLATFORMS',
p: 'Our services utilize third-party platforms including GoHighLevel, Payoneer, and others.',
p2: 'We are not responsible for changes, outages, pricing adjustments, or policy changes made by these platforms. Client subscription costs for third-party tools are the client’s responsibility unless explicitly included in a service agreement.',
},
{ h: 'SMS MESSAGING TERMS', p: 'By providing your mobile phone number and opting in through our website, contact forms, or other communication channels, you consent to receive SMS text messages from Dispatch Globally LLC d/b/a Codex Mill regarding:', ul: [ 'Appointment reminders', 'Project updates', 'Customer support communications', 'Service notifications', 'Automation implementation updates', 'Follow-up messages related to your requested services', ], p2: 'Message frequency may vary depending on your interaction with our services. Message and data rates may apply depending on your mobile carrier and service plan. You may opt out of receiving SMS messages at any time by replying STOP to any message. Once you opt out, you will no longer receive SMS messages unless you choose to opt in again. For assistance, reply HELP or contact us at info@codexmill.com. Mobile carriers are not liable for delayed or undelivered messages. By opting in to receive SMS communications from Codex Mill, a DBA of Dispatch Globally LLC, you confirm that you are at least 18 years of age.', },
{
h: 'LIMITATION OF LIABILITY',
p: 'To the fullest extent permitted by law, Codex Mill, a DBA of Dispatch Globally LLC and Dispatch Globally LLC shall not be liable for:',
ul: [
'Indirect, incidental, or consequential damages arising from the use of our services',
'Loss of revenue, leads, or business opportunities resulting from automation errors or platform downtime',
'Actions taken by the client based on our recommendations',
],
p2: 'Our total liability to any client shall not exceed the fees paid by that client in the three (3) months preceding the claim.',
},

{
h: 'TERMINATION',
p: 'Either party may terminate a service agreement with 14 days’ written notice. Upon termination:',
ul: [
'All outstanding invoices become immediately due',
'Codex Mill, a DBA of Dispatch Globally LLC will provide a handoff of completed work to the client',
'Access credentials shared with Codex Mill, a DBA of Dispatch Globally LLC will be revoked by the client',
],
},

{
h: 'GOVERNING LAW',
p: 'These Terms are governed by the laws of the State of Florida, United States, where Dispatch Globally LLC is registered. Any disputes shall be resolved through binding arbitration or in the appropriate courts of Wyoming.',
},

{
h: 'CHANGES TO THESE TERMS',
p: 'We may update these Terms from time to time. Material changes will be communicated via email or posted on CodexMill.com with an updated effective date. Continued use of our services after such changes constitutes acceptance of the updated Terms.',
},

{
h: 'CONTACT US',
p: 'If you have questions about these Terms, please contact:',
ul: [
  'Codex Mill, a DBA of Dispatch Globally LLC',
  'Email: info@codexmill.com',
  'Website: https://codexmill.com',
],
},
];

const now = new Date();

const updated = `1st ${now.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
})}`;
---

<BaseLayout title="Terms of Service" description=" Codex Mill, a DBA of Dispatch Globally LLC terms of service.">
  <section class="border-b border-hairline bg-mist py-14">
    <div class="container-page">
      <h1 class="text-display-sm text-navy">Terms of Service</h1>

  <p class="mt-3 text-sm text-cool">
    These Terms and Conditions ("Terms") govern your use of CodexMill.com and any 
services provided by Dispatch Globally LLC d/b/a Codex Mill ("we," "us," or "our"). 
By accessing our website or engaging our services, you agree to be bound by these Terms.
  </p>
</div>

  </section>

  <article class="container-page max-w-3xl py-14">
    <p class="rounded-xl border border-forge/20 bg-forge/5 p-4 text-sm text-slate">
      Last Updated: {updated}
    </p>

<div class="mt-8 space-y-8">
  {
    sections.map((s) => (
      <section>
        <h2 class="font-display text-xl font-bold text-navy">
          {s.h}
        </h2>

        {s.p && (
          <p class="mt-2 leading-relaxed text-slate">
            {s.p}
          </p>
        )}

        {s.ul && (
          <ul class="mt-3 ml-6 list-disc space-y-2 text-slate">
            {s.ul.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        )}

        {s.p2 && (
          <p class="mt-3 leading-relaxed text-slate">
            {s.p2}
          </p>
        )}
      </section>
    ))
  }
</div>

<p class="mt-12 text-sm text-cool">
  CodexMill is (a Brand of {SITE.legalName}).
</p>
  </article>
</BaseLayout>
