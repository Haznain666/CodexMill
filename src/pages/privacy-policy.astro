---

/**

* PRIVACY — stub (CLAUDE.md §5 standalone). Structure only; [CONFIRM] real legal copy.
  */
  import BaseLayout from '../layouts/BaseLayout.astro';
  import { SITE } from '../config/site';

const sections = [
{
h: 'INFORMATION WE COLLECT',
p: 'We may collect the following types of information:',
ul: [
'Contact information: name, email address, phone number, company name',
'Business information: details about your home service business, automation needs, and project requirements',
'Payment information: processed securely through Payoneer; we do not store card or bank details',
'Usage data: pages visited, time on site, referring URLs (via cookies and analytics tools)',
'Communications: emails, messages, or form submissions you send to us',
],
},

{
h: 'HOW WE USE YOUR INFORMATION',
p: 'We use collected information to:',
ul: [
'Respond to inquiries and deliver our GHL automation services',
'Send project proposals, invoices, and service-related communications',
'Improve our website and service offerings',
'Comply with legal obligations',
],
p2: 'We do not sell or share your mobile information with third parties for marketing purposes.',
},
{ h: 'SMS / TEXT MESSAGING PROGRAM', p: 'If you choose to opt in to receive SMS/text messages from Codex Mill, a DBA of Dispatch Globally LLC, you agree to receive text messages related to our services, including appointment reminders, project updates, customer support, account notifications, and follow-up communications directly related to your existing request.', ul: [ 'How You Opt In: You may opt in by submitting a contact form on our website and providing consent to receive text messages, requesting information or services from us, or providing your phone number during the client onboarding process and agreeing to receive SMS communications.', 'Message Frequency: Message frequency varies depending on your interaction with us and the services you request.', 'Message and Data Rates: Standard message and data rates may apply based on your mobile carrier\'s plan.', 'How to Opt Out: You may opt out at any time by replying STOP to any text message you receive from us. After opting out, you will no longer receive SMS communications unless you opt in again.', 'Need Help?: Reply HELP to any SMS message or contact us directly at the email address listed below for assistance.', 'Sharing of Mobile Information: We do not sell, rent, or share your mobile phone number or SMS consent with third parties or affiliates for their marketing purposes. Your information is used solely to provide the services you have requested and to communicate with you regarding your account or our services.', ], },
{
h: 'LEGAL BASIS FOR PROCESSING (GDPR / APPLICABLE LAWS)',
p: 'Where applicable, we process your data based on:',
ul: [
'Your consent (e.g., when you submit a contact form)',
'Contract performance (e.g., delivering services you have engaged us for)',
'Legitimate business interests (e.g., improving our services)',
],
},

{
h: 'DATA SHARING',
p: 'We may share your information with:',
ul: [
'Payoneer: for payment processing purposes',
'GoHighLevel (GHL): our automation platform used to manage client workflows',
'Email service providers: for client communications',
'Legal authorities: if required by law',
],
p2: 'All third-party providers are required to handle your data in compliance with applicable privacy laws.',
},

{
h: 'DATA RETENTION',
p: 'We retain your personal data only as long as necessary to fulfill the purposes outlined in this policy, or as required by law. Client project data is retained for a minimum of 3 years for business record-keeping purposes.',
},

{
h: 'COOKIES',
p: 'Our website may use cookies and similar tracking technologies to analyze site traffic and improve user experience. You may disable cookies in your browser settings, though some site features may not function as intended.',
},

{
h: 'YOUR RIGHTS',
p: 'Depending on your location, you may have the right to:',
ul: [
'Access the personal data we hold about you',
'Request correction of inaccurate data',
'Request deletion of your data',
'Withdraw consent at any time',
],
p2: 'To exercise these rights, contact us at the email below.',
},

{
h: 'SECURITY',
p: 'We implement reasonable administrative, technical, and physical safeguards to protect your information. However, no method of transmission over the internet is 100% secure.',
},

{
h: "CHILDREN'S PRIVACY",
p: 'Our services are not directed to individuals under the age of 18. We do not knowingly collect personal information from minors.',
},

{
h: 'CHANGES TO THIS POLICY',
p: 'We may update this Privacy Policy from time to time. We will notify you of material changes by updating the effective date at the top of this page.',
},
];

const now = new Date();

const updated = `1st ${now.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
})}`;
---

<BaseLayout title="Privacy Policy" description="CodexMill privacy policy.">
  <section class="border-b border-hairline bg-mist py-14">
    <div class="container-page">
      <h1 class="text-display-sm text-navy">Privacy Policy</h1>

  <p class="mt-3 text-sm text-cool">
    This Privacy Policy describes how Codex Mill, a Doing Business As (DBA) of Dispatch Globally LLC (“we,” “us,” or “our”),
    collects, uses, and protects
    information when you visit codexmill.com or engage our services.
  </p>
</div>

  </section>

  <article class="container-page max-w-3xl py-14">
    <p class="rounded-xl border border-forge/20 bg-forge/5 p-4 text-sm text-slate">
      Last Updated: {updated}
    </p>

<div class="mt-8 space-y-8">
  {
    sections.map((s) => (
      <section>
        <h2 class="font-display text-xl font-bold text-navy">
          {s.h}
        </h2>

        {s.p && (
          <p class="mt-2 leading-relaxed text-slate">
            {s.p}
          </p>
        )}

        {s.ul && (
          <ul class="mt-3 ml-6 list-disc space-y-2 text-slate">
            {s.ul.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        )}

        {s.p2 && (
          <p class="mt-3 leading-relaxed text-slate">
            {s.p2}
          </p>
        )}
      </section>
    ))
  }
</div>

<p class="mt-12 text-sm text-cool">
  CodexMill is a service of {SITE.legalName}.
</p>
  </article>
</BaseLayout>


