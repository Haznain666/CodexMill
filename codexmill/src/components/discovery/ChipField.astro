---
/**
 * ChipField — FormField + a grid of selectable chip buttons.
 *   select="multi"  → checkbox squares (toggle many)
 *   select="single" → radio circles (pick one)
 * Selection state + styling is driven by the wizard engine (DiscoveryForm),
 * consistent with the rest of the form. Chips are real <button>s (keyboard-ok).
 */
import FormField from './FormField.astro';
import Icon from '../Icon.astro';

interface Props {
  label: string;
  name: string;
  options: string[];
  select?: 'multi' | 'single';
  required?: boolean;
  help?: string;
  class?: string;
}
const { label, name, options, select = 'multi', required = false, help, class: className = '' } =
  Astro.props;
const isMulti = select === 'multi';
---

<FormField label={label} name={name} required={required} help={help} class={className}>
  <div data-chipgroup data-select={select} role={isMulti ? 'group' : 'radiogroup'} aria-label={label} class="grid gap-2.5 sm:grid-cols-2">
    {
      options.map((opt) => (
        <button
          type="button"
          data-chip
          data-value={opt}
          role={isMulti ? 'checkbox' : 'radio'}
          aria-checked="false"
          class="flex items-center gap-3 rounded-xl border border-hairline bg-white px-4 py-3 text-left text-sm font-medium text-navy transition hover:border-forge/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-forge/30"
        >
          <span
            data-indicator
            class:list={[
              'grid h-5 w-5 shrink-0 place-items-center border-2 border-cool text-white transition',
              isMulti ? 'rounded-[6px]' : 'rounded-full',
            ]}
          >
            {isMulti ? (
              <Icon name="check" size={13} weight={3} class="hidden" data-chip-check />
            ) : (
              <span data-chip-dot class="hidden h-2 w-2 rounded-full bg-white" />
            )}
          </span>
          <span>{opt}</span>
        </button>
      ))
    }
  </div>
</FormField>
