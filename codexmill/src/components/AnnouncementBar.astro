---
/**
 * AnnouncementBar — site-wide, dismissible Founder Members promo (CLAUDE.md §5, §7.2).
 * Dismissal persists via localStorage so it stays closed across pages/visits.
 * Renders nothing if FOUNDER.enabled is false.
 */
import { FOUNDER } from '../config/site';

const { announcement, enabled, spotsRemaining } = FOUNDER;
const spotsNote =
  typeof spotsRemaining === 'number' ? ` Only ${spotsRemaining} spots left.` : '';
---

{
  enabled && (
    <div
      id="announcement-bar"
      data-dismiss-key={announcement.dismissKey}
      class="relative z-50 hidden bg-navy text-white"
    >
      <div class="bg-forge-blue-soft">
        <div class="container-page flex items-center justify-center gap-x-3 gap-y-1 py-2.5 text-center text-[0.82rem] sm:text-sm">
          <p class="font-medium leading-snug">
            <span aria-hidden="true">🚀</span>{' '}
            <span class="font-semibold">{announcement.text}</span>
            {spotsNote && <span class="text-forge-500">{spotsNote}</span>}{' '}
            <a
              href={announcement.ctaHref}
              target="_blank"
              rel="noopener noreferrer"
              class="ml-1 inline-flex items-center gap-1 font-semibold text-forge-500 underline decoration-forge/40 underline-offset-4 transition hover:text-white hover:decoration-white"
            >
              {announcement.ctaLabel}
              <span aria-hidden="true">→</span>
            </a>
          </p>
          <button
            id="announcement-dismiss"
            type="button"
            aria-label="Dismiss announcement"
            class="absolute right-3 top-1/2 grid h-7 w-7 -translate-y-1/2 place-items-center rounded-lg text-white/70 transition hover:bg-white/10 hover:text-white"
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  )
}

<script>
  // Show only if not previously dismissed; remember dismissal.
  const bar = document.getElementById('announcement-bar');
  if (bar) {
    const key = bar.dataset.dismissKey || 'cm-announcement-dismissed';
    let dismissed = false;
    try {
      dismissed = localStorage.getItem(key) === '1';
    } catch {
      /* storage blocked — show by default */
    }
    if (!dismissed) {
      bar.classList.remove('hidden');
      document.documentElement.classList.add('has-announcement');
    }
    document.getElementById('announcement-dismiss')?.addEventListener('click', () => {
      bar.style.display = 'none';
      document.documentElement.classList.remove('has-announcement');
      try {
        localStorage.setItem(key, '1');
      } catch {
        /* ignore */
      }
    });
  }
</script>
