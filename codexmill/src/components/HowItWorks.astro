---
/**
 * HowItWorks — the recurring four-step model (Capture / Follow Up / Book / Grow),
 * reframed per page via the `steps` prop. Connected by a flow line on desktop.
 */
import Icon from './Icon.astro';
import SectionReveal from './SectionReveal.astro';
import SectionHeading from './SectionHeading.astro';

export interface Step {
  label: string;
  title: string;
  body: string;
  icon: string;
  note?: string;
}

interface Props {
  heading?: string;
  highlight?: string;
  subhead?: string;
  steps: Step[];
  class?: string;
}
const {
  heading = 'One System. Every Lead, Handled.',
  highlight,
  subhead,
  steps,
  class: className = '',
} = Astro.props;
---

<section id="how-it-works" class={`relative bg-white py-20 sm:py-24 ${className}`}>
  <div class="container-page">
    <SectionReveal>
      <SectionHeading heading={heading} highlight={highlight} subhead={subhead} />
    </SectionReveal>

    <div class="relative mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <!-- connector line (desktop) -->
      <div
        class="absolute left-0 right-0 top-9 hidden h-px bg-gradient-to-r from-transparent via-hairline to-transparent lg:block"
        aria-hidden="true"
      >
      </div>

      {
        steps.map((step, i) => (
          <SectionReveal delay={i * 110} class="relative">
            <div class="group flex h-full flex-col rounded-2xl border border-hairline bg-white p-6 shadow-soft transition duration-300 hover:-translate-y-1 hover:shadow-card hover:border-forge/20">
              <div class="relative mb-5 inline-flex">
                <span class="grid h-[4.5rem] w-[4.5rem] place-items-center rounded-2xl bg-forge-blue-soft text-navy ring-1 ring-hairline">
                  <Icon name={step.icon as any} size={28} />
                </span>
                <span class="absolute -right-1.5 -top-1.5 grid h-6 w-6 place-items-center rounded-full bg-navy text-[0.7rem] font-bold text-white">
                  {i + 1}
                </span>
              </div>
              <p class="text-xs font-semibold uppercase tracking-widest text-ember">{step.label}</p>
              <h3 class="mt-1.5 text-xl font-bold text-navy">{step.title}</h3>
              <p class="mt-2 text-[0.95rem] leading-relaxed text-slate">{step.body}</p>
              {step.note && <p class="mt-3 text-xs font-medium text-cool">{step.note}</p>}
            </div>
          </SectionReveal>
        ))
      }
    </div>
  </div>
</section>
