---
/**
 * Footer — link columns, master tagline, contact, legal fine print (CLAUDE.md §5; copy deck).
 */
import { SITE, FOOTER_NAV, GET_STARTED_URL, CTA_LABEL } from '../config/site';
import Logo from './Logo.astro';
import Button from './Button.astro';

const year = new Date().getFullYear();
const isExternal = (href: string) => /^https?:\/\//.test(href);
---

<footer class="border-t border-navy/10 bg-navy text-white/80">
  <div class="container-page py-14">
    <!-- Top: brand + CTA -->
    <div class="flex flex-col gap-8 border-b border-white/10 pb-10 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-md">
              <a href="/" class="shrink-0 rounded-lg" aria-label="CodexMill home">
  <img src="/codexmill1.png" alt="Codex Mill Logo" class="h-10 w-auto" />
      </a>
        <p class="mt-4 font-display text-xl font-bold text-white">{SITE.masterTagline}</p>
        <p class="mt-2 text-sm text-white/60">{SITE.positioning}</p>
      </div>
    </div>

    <!-- Link columns -->
    <div class="grid grid-cols-2 gap-8 py-10 sm:grid-cols-4">
      {
        Object.entries(FOOTER_NAV).map(([heading, links]) => (
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-white/50">{heading}</h2>
            <ul class="mt-4 space-y-2.5">
              {links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-white/75 transition hover:text-forge-500"
                    {...(isExternal(link.href) ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Contact -->
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 border-t border-white/10 pt-8 text-sm text-white/60">
      {
        SITE.contact.email && (
          <a href={`mailto:${SITE.contact.email}`} class="transition hover:text-forge-500">
            {SITE.contact.email}
          </a>
        )
      }
      {
        SITE.contact.phone && (
          <a href={`tel:+12397226339`} class="transition hover:text-forge-500">
            {SITE.contact.phone}
          </a>
        )
      }
      {!SITE.contact.phone && <span class="text-white/40">
        <a href={`tel:+12397226339`} class="transition hover:text-forge-500">
            {SITE.contact.phone}
          </a>
          </span>}
    </div>


    <!-- Fine print -->
    <div class="mt-8 flex flex-col gap-2 text-xs text-white/45 sm:flex-row sm:items-center sm:justify-between">
      <p>
        CodexMill is a DBA of {SITE.legalName}. Registered at 7901 4th St N, #30060 St. Petersburg, FL 33702, USA © {year}. All rights reserved.
      </p>
      <p class="flex gap-4">
        <a href="/privacy-policy" target="_blank" class="transition hover:text-white/80">Privacy</a>
        <a href="/terms-condition" target="_blank" class="transition hover:text-white/80">Terms</a>
      </p>
    </div>
  </div>
</footer>
