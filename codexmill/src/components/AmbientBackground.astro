---
/**
 * AmbientBackground — soft blurred mesh blobs (pale orange + pale blue) that
 * drift behind white sections for subtle depth (CLAUDE.md §4A). Decorative;
 * pointer-events-none and aria-hidden. Drift pauses under reduced-motion.
 */
interface Props {
  /** intensity of the blobs */
  variant?: 'subtle' | 'hero';
  class?: string;
}
const { variant = 'subtle', class: className = '' } = Astro.props;
const opacity = variant === 'hero' ? 'opacity-80' : 'opacity-50';
---

<div class={`pointer-events-none absolute inset-0 -z-10 overflow-hidden ${opacity} ${className}`} aria-hidden="true">
  <div class="absolute -left-24 -top-24 h-[28rem] w-[28rem] rounded-full bg-forge/[0.10] blur-3xl motion-safe:animate-drift"></div>
  <div
    class="absolute -right-20 top-10 h-[24rem] w-[24rem] rounded-full bg-circuit/[0.10] blur-3xl motion-safe:animate-drift"
    style="animation-delay:-6s"
  >
  </div>
  {
    variant === 'hero' && (
      <div
        class="absolute bottom-[-8rem] left-1/3 h-[22rem] w-[22rem] rounded-full bg-forge/[0.07] blur-3xl motion-safe:animate-drift"
        style="animation-delay:-11s"
      />
    )
  }
</div>
