---
/**
 * Header — sticky top nav. Frosted-white on scroll, Industries + Our Services
 * dropdowns (hover/focus on desktop, accordion in the mobile menu), and a
 * persistent Forge "Book Free Audit" button (CLAUDE.md §5 nav behavior).
 */
import { NAV, GET_STARTED_URL, CTA_LABEL_SHORT, CTA_LABEL } from '../config/site';
import Button from './Button.astro';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header id="site-header" class="sticky top-0 z-40 transition-all duration-300">
  <div
    id="header-inner"
    class="border-b border-transparent transition-all duration-300"
  >
    <nav class="container-page flex h-16 items-center justify-between gap-4 lg:h-[4.5rem]" aria-label="Primary">
      <!-- Logo -->
      <a href="/" class="shrink-0 rounded-lg" aria-label="CodexMill home">
  <img src="/codexmill.png" alt="Codex Mill Logo" class="h-10 w-auto" />
      </a>

      <!-- Desktop nav -->
      <ul class="hidden items-center gap-1 lg:flex">
        {
          NAV.map((item) =>
            item.children ? (
              <li class="group relative">
                <button
                  type="button"
                  class:list={[
                    'flex items-center gap-1.5 rounded-lg px-3.5 py-2 text-[0.95rem] font-medium transition',
                    isActive(item.href) ? 'text-forge' : 'text-navy hover:text-forge',
                  ]}
                  aria-expanded="false"
                  aria-haspopup="true">

                  {item.label}
                  <svg
                    width="11"
                    height="11"
                    viewBox="0 0 12 12"
                    fill="none"
                    aria-hidden="true"
                    class="mt-0.5 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180">
                    
                    <path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>
                {/* Dropdown */}
                <div class="invisible absolute left-1/2 top-full z-10 w-72 -translate-x-1/2 translate-y-1 pt-2 opacity-0 transition-all duration-200 ease-out group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100">
                  <div class="glass overflow-hidden rounded-2xl p-2">
                    <a
                      href={item.href}
                      class="block rounded-xl px-3.5 py-2.5 text-sm font-semibold text-navy transition hover:bg-mist"
                    >
                      All {item.label} <span aria-hidden="true" class="text-forge">→</span>
                    </a>
                    <div class="my-1 h-px bg-hairline" />
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class="block rounded-xl px-3.5 py-2.5 transition hover:bg-mist"
                      >
                        <span class="block text-sm font-semibold text-navy">{child.label}</span>
                        {child.description && (
                          <span class="block text-xs text-cool">{child.description}</span>
                        )}
                      </a>
                    ))}
                  </div>
                </div>
              </li>
              
            ) : (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'rounded-lg px-3.5 py-2 text-[0.95rem] font-medium transition',
                    isActive(item.href) ? 'text-forge' : 'text-navy hover:text-forge',
                  ]}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            )
          )
        }
      </ul>

      <!-- Desktop CTA -->
      <div class="hidden lg:block">
        <Button href={GET_STARTED_URL} size="sm" aria-label={CTA_LABEL}>{CTA_LABEL_SHORT}</Button>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="grid h-10 w-10 place-items-center rounded-lg text-navy transition hover:bg-mist lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <svg id="icon-close" class="hidden" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 5l14 14M19 5L5 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="fixed inset-x-0 bottom-0 top-[var(--header-offset,4rem)] z-30 hidden overflow-y-auto bg-white lg:hidden"
  >
    <div class="container-page flex flex-col gap-1 py-5">
      {
        NAV.map((item) =>
          item.children ? (
            <details class="group border-b border-hairline">
              <summary class="flex cursor-pointer list-none items-center justify-between py-3.5 text-lg font-semibold text-navy">
                {item.label}
                <svg width="16" height="16" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="text-cool transition-transform group-open:rotate-180">
                  <path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </summary>
              <div class="flex flex-col gap-0.5 pb-3 pl-1">
                <a href={item.href} class="py-2 text-sm font-semibold text-forge">
                  All {item.label} →
                </a>
                {item.children.map((child) => (
                  <a href={child.href} class="py-2 text-base text-slate">
                    {child.label}
                  </a>
                ))}
              </div>
            </details>
          ) : (
            <a
              href={item.href}
              class:list={[
                'border-b border-hairline py-3.5 text-lg font-semibold',
                isActive(item.href) ? 'text-forge' : 'text-navy',
              ]}
            >
              {item.label}
            </a>
          )
        )
      }
      <div class="pt-5">
        <Button href={GET_STARTED_URL} size="lg" class="w-full">{CTA_LABEL}</Button>
      </div>
    </div>
  </div>
</header>

<script>
  // --- Frosted-white on scroll ---
  const inner = document.getElementById('header-inner');
  const onScroll = () => {
    if (!inner) return;
    if (window.scrollY > 8) {
      inner.classList.add('glass', 'border-hairline', 'shadow-soft');
    } else {
      inner.classList.remove('glass', 'border-hairline', 'shadow-soft');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // --- Mobile menu toggle ---
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  const setMenu = (open: boolean) => {
    if (!menu || !toggle) return;
    menu.classList.toggle('hidden', !open);
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    document.body.style.overflow = open ? 'hidden' : '';
  };

  toggle?.addEventListener('click', () => {
    const open = menu?.classList.contains('hidden');
    setMenu(Boolean(open));
  });
  // Close when a link is tapped, or on resize to desktop.
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) setMenu(false);
  });
</script>