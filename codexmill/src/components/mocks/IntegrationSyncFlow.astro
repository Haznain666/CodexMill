---
/**
 * IntegrationSyncFlow — stylised (NOT real product UI) two-app sync animation
 * used as the signature hero visual for integration pages. Left card = your
 * operations tool, right card = GHL, with an animated data ribbon between
 * them and a synced-record checklist below.
 */
interface Props {
  /** Left-side app label (e.g. "Housecall Pro", "Jobber"). */
  leftLabel: string;
  /** Left-side kicker under the label. */
  leftKicker?: string;
  /** Right side is always GHL, but caller can override subheader. */
  rightKicker?: string;
  /** Accent color for the left card ring / dot. */
  leftAccent?: 'forge' | 'circuit';
  class?: string;
}
const {
  leftLabel,
  leftKicker = 'Field operations',
  rightKicker = 'CRM · Automation · Marketing',
  leftAccent = 'circuit',
  class: className = '',
} = Astro.props;

const leftRing = leftAccent === 'forge' ? 'ring-forge/30' : 'ring-circuit/30';
const leftDot = leftAccent === 'forge' ? 'bg-forge' : 'bg-circuit';

// Records shown as syncing between the two systems
const syncItems = [
  { label: 'New customer', direction: '→', tag: 'Contact' },
  { label: 'Job scheduled', direction: '↔', tag: 'Pipeline' },
  { label: 'Estimate sent', direction: '→', tag: 'Opportunity' },
  { label: 'Invoice paid', direction: '←', tag: 'Trigger' },
  { label: 'Job completed', direction: '→', tag: 'Review req.' },
];
---

<div class={`relative ${className}`}>
  <!-- top row: two system cards with a data ribbon between -->
  <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3 sm:gap-4">
    <!-- LEFT: your operations tool -->
    <div class={`rounded-2xl border border-hairline bg-white p-4 shadow-soft ring-2 ${leftRing} motion-safe:animate-float-slow`}>
      <div class="flex items-center gap-2.5">
        <span class={`h-2.5 w-2.5 rounded-full ${leftDot}`}></span>
        <div class="min-w-0">
          <p class="truncate font-display text-sm font-bold text-navy">{leftLabel}</p>
          <p class="truncate text-[0.65rem] font-medium uppercase tracking-wider text-cool">{leftKicker}</p>
        </div>
      </div>
      <div class="mt-3 space-y-1.5">
        <div class="h-1.5 w-full rounded-full bg-mist"></div>
        <div class="h-1.5 w-4/5 rounded-full bg-mist"></div>
        <div class="h-1.5 w-2/3 rounded-full bg-mist"></div>
      </div>
    </div>

    <!-- SYNC ribbon -->
    <div class="relative flex flex-col items-center">
      <div class="cm-ribbon relative h-10 w-10 rounded-full bg-gradient-to-br from-forge to-circuit shadow-glow" aria-hidden="true">
        <span class="absolute inset-0 grid place-items-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 3l4 4-4 4M21 7H10a4 4 0 0 0 0 8h3" />
            <path d="M7 21l-4-4 4-4M3 17h11a4 4 0 0 0 0-8h-3" />
          </svg>
        </span>
        <span class="pointer-events-none absolute -inset-3 rounded-full bg-forge/30 blur-xl motion-safe:animate-pulse"></span>
      </div>
      <p class="mt-2 text-[0.6rem] font-semibold uppercase tracking-widest text-cool">Two-way</p>
    </div>

    <!-- RIGHT: GHL -->
    <div class="rounded-2xl border border-hairline bg-white p-4 shadow-soft ring-2 ring-forge/30 motion-safe:animate-float-slow" style="animation-delay:-3s">
      <div class="flex items-center gap-2.5">
        <span class="h-2.5 w-2.5 rounded-full bg-forge"></span>
        <div class="min-w-0">
          <p class="truncate font-display text-sm font-bold text-navy">GoHighLevel</p>
          <p class="truncate text-[0.65rem] font-medium uppercase tracking-wider text-cool">{rightKicker}</p>
        </div>
      </div>
      <div class="mt-3 grid grid-cols-3 gap-1.5">
        <div class="h-6 rounded-md bg-mist"></div>
        <div class="h-6 rounded-md bg-forge/15"></div>
        <div class="h-6 rounded-md bg-mist"></div>
      </div>
    </div>
  </div>

  <!-- bottom row: syncing records list -->
  <div class="mt-4 rounded-2xl border border-hairline bg-white p-4 shadow-soft">
    <div class="flex items-center justify-between">
      <p class="text-[0.65rem] font-semibold uppercase tracking-widest text-cool">Live sync</p>
      <span class="flex items-center gap-1.5 text-[0.65rem] font-semibold text-[#1FA34A]">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#1FA34A] opacity-60"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-[#1FA34A]"></span>
        </span>
        Streaming
      </span>
    </div>
    <ul class="mt-3 divide-y divide-hairline">
      {
        syncItems.map((it, i) => (
          <li
            class="cm-sync-row flex items-center justify-between py-2 text-sm"
            style={`--i:${i}`}
          >
            <span class="flex items-center gap-2.5 truncate">
              <span class="grid h-6 w-6 place-items-center rounded-md bg-forge-blue-soft text-[0.65rem] font-bold text-navy ring-1 ring-hairline">
                {it.tag.charAt(0)}
              </span>
              <span class="truncate font-medium text-navy">{it.label}</span>
            </span>
            <span class="ml-3 flex items-center gap-2 whitespace-nowrap text-xs font-semibold text-cool">
              <span class="text-forge">{it.direction}</span>
              <span class="rounded-full bg-mist px-2 py-0.5 ring-1 ring-hairline">{it.tag}</span>
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style>
  .cm-ribbon {
    animation: cm-spin 8s linear infinite;
  }
  @keyframes cm-spin {
    to { transform: rotate(360deg); }
  }
  .cm-sync-row {
    opacity: 0;
    transform: translateY(6px);
    animation: cm-row-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--i) * 120ms + 400ms);
  }
  @keyframes cm-row-in {
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cm-ribbon, .cm-sync-row { animation: none !important; opacity: 1 !important; transform: none !important; }
  }
</style>
