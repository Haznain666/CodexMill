---
/**
 * FunnelSite — stylised (NOT real-product) high-converting landing page + funnel
 * with a wired-in booking form. For the Website Design page signature.
 */
---

<div class="p-0">
  <!-- mini hero -->
  <div class="relative overflow-hidden bg-navy px-5 py-6 text-white">
    <div class="pointer-events-none absolute -right-6 -top-6 h-24 w-24 rounded-full bg-forge/30 blur-2xl"></div>
    <div class="relative grid grid-cols-[1.3fr_1fr] items-center gap-4">
      <div>
        <div class="h-2 w-16 rounded-full bg-white/30"></div>
        <div class="mt-2 h-3.5 w-32 rounded bg-white/80"></div>
        <div class="mt-1.5 h-3.5 w-24 rounded bg-forge"></div>
        <div class="mt-3 h-2 w-36 rounded bg-white/25"></div>
        <div class="mt-3 inline-flex rounded-lg bg-forge px-3 py-1.5 text-[0.62rem] font-bold">Book Now</div>
      </div>
      <!-- booking form card -->
      <div class="rounded-xl bg-white p-3 shadow-glass">
        <p class="text-[0.6rem] font-bold uppercase tracking-wide text-navy">Get a quote</p>
        <div class="mt-2 space-y-1.5">
          <div class="h-5 rounded-md bg-mist ring-1 ring-hairline"></div>
          <div class="h-5 rounded-md bg-mist ring-1 ring-hairline"></div>
          <div class="h-5 rounded-md bg-forge text-center text-[0.55rem] font-bold leading-5 text-white">Book my visit</div>
        </div>
      </div>
    </div>
  </div>

  <!-- trust + features row -->
  <div class="space-y-3 p-5">
    <div class="flex items-center justify-between rounded-xl bg-mist px-3 py-2">
      <span class="text-forge text-xs">★★★★★</span>
      <div class="h-1.5 w-20 rounded bg-navy/15"></div>
      <span class="rounded bg-[#28C840]/15 px-1.5 py-0.5 text-[0.55rem] font-bold text-[#1FA34A]">Verified</span>
    </div>
    <div class="grid grid-cols-3 gap-2">
      {Array.from({ length: 3 }).map(() => (
        <div class="rounded-xl border border-hairline p-2.5">
          <div class="h-6 w-6 rounded-lg bg-circuit/15"></div>
          <div class="mt-2 h-1.5 w-10 rounded bg-navy/15"></div>
          <div class="mt-1 h-1.5 w-7 rounded bg-navy/10"></div>
        </div>
      ))}
    </div>
  </div>
</div>
